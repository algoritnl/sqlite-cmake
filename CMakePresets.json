{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "_diagnostics",
      "hidden": true,
      "warnings": {
        "dev": true,
        "deprecated": true,
        "uninitialized": true,
        "unusedCli": true,
        "systemVars": false
      },
      "errors": {
        "dev": false,
        "deprecated": false
      },
      "debug": {
        "output": false,
        "tryCompile": false,
        "find": false
      },
      "cacheVariables": {
        "CMAKE_MESSAGE_LOG_LEVEL": "STATUS",
        "CMAKE_REQUIRED_QUIET": "OFF"
      }
    },
    {
      "name": "_compiler",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang"
      }
    },
    {
      "name": "_generator",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build",
      "installDir": "${sourceDir}/stage",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_DEFAULT_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_DEBUG_POSTFIX": "-dbg"
      }
    },
    {
      "name": "_project",
      "hidden": true,
      "cacheVariables": {
        "SQLITE_BUILD_SHELL": "ON",
        "SQLITE_DEFAULT_MEMSTATUS": "1",
        "SQLITE_DEFAULT_SYNCHRONOUS": "2",
        "SQLITE_DEFAULT_WAL_SYNCHRONOUS": "1",
        "SQLITE_DQS": "0",
        "SQLITE_ENABLE_API_ARMOR": "ON",
        "SQLITE_ENABLE_COLUMN_METADATA": "ON",
        "SQLITE_ENABLE_DBSTAT_VTAB": "ON",
        "SQLITE_ENABLE_EXPLAIN_COMMENTS": "ON",
        "SQLITE_ENABLE_FTS5": "ON",
        "SQLITE_ENABLE_GEOPOLY": "ON",
        "SQLITE_ENABLE_ICU": "OFF",
        "SQLITE_ENABLE_MATH_FUNCTIONS": "ON",
        "SQLITE_ENABLE_NORMALIZE": "ON",
        "SQLITE_ENABLE_PREUPDATE_HOOK": "ON",
        "SQLITE_ENABLE_RBU": "ON",
        "SQLITE_ENABLE_RTREE": "ON",
        "SQLITE_ENABLE_SESSION": "ON",
        "SQLITE_ENABLE_STMTVTAB": "ON",
        "SQLITE_LIKE_DOESNT_MATCH_BLOBS": "ON",
        "SQLITE_MAX_EXPR_DEPTH": "0",
        "SQLITE_OMIT_DEPRECATED": "ON",
        "SQLITE_THREADSAFE": "1"
      }
    },
    {
      "name": "default",
      "inherits": [
        "_diagnostics",
        "_compiler",
        "_generator",
        "_project"
      ]
    },
    {
      "name": "shared",
      "inherits": "default",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "static",
      "inherits": "default",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "jobs": 8,
      "targets": "all",
      "cleanFirst": false,
      "verbose": true
    },
    {
      "name": "debug-shared",
      "inherits": "default",
      "configurePreset": "shared",
      "configuration": "Debug"
    },
    {
      "name": "debug-static",
      "inherits": "default",
      "configurePreset": "static",
      "configuration": "Debug"
    },
    {
      "name": "release-shared",
      "inherits": "default",
      "configurePreset": "shared",
      "configuration": "Release"
    },
    {
      "name": "release-static",
      "inherits": "default",
      "configurePreset": "static",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "shortProgress": false,
        "verbosity": "extra",
        "debug": false,
        "outputOnFailure": true,
        "quiet": false
      },
      "execution": {
        "stopOnFailure": false,
        "jobs": 8,
        "timeout": 300,
        "noTestsAction": "ignore"
      }
    },
    {
      "name": "debug-shared",
      "inherits": "default",
      "configurePreset": "shared",
      "configuration": "Debug"
    },
    {
      "name": "debug-static",
      "inherits": "default",
      "configurePreset": "static",
      "configuration": "Debug"
    },
    {
      "name": "release-shared",
      "inherits": "default",
      "configurePreset": "shared",
      "configuration": "Release"
    },
    {
      "name": "release-static",
      "inherits": "default",
      "configurePreset": "static",
      "configuration": "Release"
    }
  ],
  "packagePresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "debug": false,
        "verbose": true
      },
      "configurations": ["Debug", "Release"],
      "generators": ["TGZ"]
    },
    {
      "name": "shared",
      "inherits": "default",
      "configurePreset": "shared"
    },
    {
      "name": "static",
      "inherits": "default",
      "configurePreset": "static"
    }
  ],
  "workflowPresets": [
    {
      "name": "ci-shared",
      "steps": [
        {
          "type": "configure",
          "name": "shared"
        },
        {
          "type": "build",
          "name": "debug-shared"
        },
        {
          "type": "test",
          "name": "debug-shared"
        },
        {
          "type": "build",
          "name": "release-shared"
        },
        {
          "type": "test",
          "name": "release-shared"
        },
        {
          "type": "package",
          "name": "shared"
        }
      ]
    },
    {
      "name": "ci-static",
      "steps": [
        {
          "type": "configure",
          "name": "static"
        },
        {
          "type": "build",
          "name": "debug-static"
        },
        {
          "type": "test",
          "name": "debug-static"
        },
        {
          "type": "build",
          "name": "release-static"
        },
        {
          "type": "test",
          "name": "release-static"
        },
        {
          "type": "package",
          "name": "static"
        }
      ]
    }
  ]
}
